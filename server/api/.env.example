# OpenRouter API credentials
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model fallback lists — comma-separated, tried in priority order.
# Defaults shown below; override to change priority or add/remove models.
OPENROUTER_INVESTIGATION_MODELS=nvidia/nemotron-3-super-120b-a12b:free,minimax/minimax-m2.5:free
OPENROUTER_DETECTOR_MODELS=nvidia/nemotron-3-super-120b-a12b:free,minimax/minimax-m2.5:free
